GEMINI_API_KEY=your_gemini_api_key_here
# 可选，默认 gemini-2.5-flash。免费档不同模型配额分开计，可换 gemini-2.0-flash / gemini-2.0-flash-lite
MODEL=gemini-2.5-flash
MUSIC_BASE_URL=http://localhost:5173/music
# 管理后台：登录密码（设为强随机串；留空则管理后台禁用）与 session cookie 签名密钥
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-in-prod
