jsx// src/hooks/useGestureControl.js
import { useState, useCallback } from 'react';

export function useGestureControl() {
  const [handPosition, setHandPosition] = useState({ x: 0, y: 0 });
  const [gestureState, setGestureState] = useState('idle');
  const [chargeProgress, setChargeProgress] = useState(0);
  
  let chargeStartTime = null;
  const CHARGE_DURATION = 1000; // 1秒蓄力

  const isFist = (landmarks) => {
    const wrist = landmarks[0];
    const tips = [8, 12, 16, 20];
    let avgDist = 0;
    
    tips.forEach(idx => {
      const tip = landmarks[idx];
      const d = Math.sqrt(
        Math.pow(tip.x - wrist.x, 2) + 
        Math.pow(tip.y - wrist.y, 2)
      );
      avgDist += d;
    });
    
    return (avgDist / tips.length) < 0.23;
  };

  const handleGesture = useCallback((landmarks) => {
    const palm = landmarks[9];
    const screenX = (1 - palm.x) * window.innerWidth;
    const screenY = palm.y * window.innerHeight;
    
    setHandPosition({ x: screenX, y: screenY });

    if (isFist(landmarks)) {
      if (gestureState !== 'charging') {
        chargeStartTime = Date.now();
        setGestureState('charging');
      }

      const elapsed = Date.now() - chargeStartTime;
      const progress = Math.min(elapsed / CHARGE_DURATION, 1);
      setChargeProgress(progress);

      if (elapsed > CHARGE_DURATION) {
        setGestureState('triggered');
        return 'fist_complete';
      }
    } else {
      if (gestureState === 'charging') {
        setGestureState('idle');
        setChargeProgress(0);
      }
    }

    return null;
  }, [gestureState]);

  return {
    handPosition,
    gestureState,
    chargeProgress,
    handleGesture
  };
}
