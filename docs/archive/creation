jsx// src/components/GestureCamera.jsx
import React, { useEffect, useRef } from 'react';
import { Hands } from '@mediapipe/hands';
import { Camera } from '@mediapipe/camera_utils';

export function GestureCamera({ onHandDetected }) {
  const videoRef = useRef(null);
  const canvasRef = useRef(null);

  useEffect(() => {
    const hands = new Hands({
      locateFile: (file) => {
        return `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`;
      }
    });

    hands.setOptions({
      maxNumHands: 1,
      modelComplexity: 1,
      minDetectionConfidence: 0.7,
      minTrackingConfidence: 0.7
    });

    hands.onResults((results) => {
      if (results.multiHandLandmarks?.[0]) {
        onHandDetected(results.multiHandLandmarks[0]);
      }
    });

    const camera = new Camera(videoRef.current, {
      onFrame: async () => {
        await hands.send({ image: videoRef.current });
      },
      width: 320,
      height: 240
    });

    camera.start();

    return () => camera.stop();
  }, [onHandDetected]);

  return (
    <video
      ref={videoRef}
      className="fixed bottom-4 right-4 w-40 h-30 rounded-lg opacity-50 scale-x-[-1] border border-cyan-500"
      playsInline
    />
  );
}
